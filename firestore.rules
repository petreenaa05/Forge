rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── DEV / DEMO rules ─────────────────────────────────
    // Firebase Auth is bypassed (dummy auth), so request.auth
    // is always null.  Open all collections for dev/demo use.
    // TODO: Re-add proper auth checks before any production release.

    match /users/{userId} {
      allow read, write: if true;
    }

    match /jobs/{jobId} {
      allow read, write: if true;
    }

    match /reviews/{reviewId} {
      allow read, write: if true;
    }

    match /chats/{chatId} {
      allow read, write: if true;

      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    match /user_presence/{userId} {
      allow read, write: if true;
    }
  }
}
